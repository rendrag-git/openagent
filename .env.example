# Copy this file to .env and fill in real values
# DO NOT commit .env — it is gitignored

# HOME is used to locate ~/.openclaw/openagent/ (parked sessions, routing table, etc.)
# HOME=

# Git identity for worktree snapshot commits (defaults to "openagent" / "openagent@local")
# GIT_AUTHOR_NAME=openagent
# GIT_AUTHOR_EMAIL=openagent@local
# GIT_COMMITTER_NAME=openagent
# GIT_COMMITTER_EMAIL=openagent@local
